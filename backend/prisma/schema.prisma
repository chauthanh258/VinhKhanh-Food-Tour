generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OWNER
  USER
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String?   @map("full_name")
  role          Role      @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  pois          POI[]     @relation("OwnerPois")

  @@map("users")
}

model POI {
  id           String           @id @default(uuid()) @db.Uuid
  lat          Float
  lng          Float
  rating       Decimal          @default(0.0) @db.Decimal(2, 1)
  ownerId      String?          @map("owner_id") @db.Uuid
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at")

  owner        User?            @relation("OwnerPois", fields: [ownerId], references: [id], onDelete: SetNull)
  translations POITranslation[]
  menuItems    MenuItem[]

  @@index([lat, lng])
  @@map("pois")
}

model POITranslation {
  id           String   @id @default(uuid()) @db.Uuid
  poiId        String   @map("poi_id") @db.Uuid
  language     String   @db.VarChar(10) // 'vi', 'en', 'ja', 'ko', 'zh'
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  specialties  String?  @db.Text
  priceRange   String?  @map("price_range") @db.VarChar(100)
  audioUrl     String?  @map("audio_url") @db.VarChar(255)
  imageUrl     String?  @map("image_url") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  poi          POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([poiId, language])
  @@map("poi_translations")
}

model MenuItem {
  id          String   @id @default(uuid()) @db.Uuid
  poiId       String   @map("poi_id") @db.Uuid
  name        String   @db.VarChar(255)
  price       Decimal? @db.Decimal(12, 2)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(255)
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  poi         POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}
