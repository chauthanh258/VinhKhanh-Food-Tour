generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poi {
  id           String           @id @default(uuid())
  lat          Float
  lng          Float
  translations PoiTranslation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model PoiTranslation {
  id          String  @id @default(uuid())
  poiId       String
  poi         Poi     @relation(fields: [poiId], references: [id], onDelete: Cascade)
  language    String // 'vi', 'en', 'ko', 'zh', vv
  name        String
  description String?
  audioUrl    String?
  imageUrl    String?

  @@unique([poiId, language]) // Mỗi POI chỉ có 1 bản dịch tương ứng mỗi ngôn ngữ
}
